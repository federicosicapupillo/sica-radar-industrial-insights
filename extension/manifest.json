{
  "manifest_version": 3,
  "name": "Brain Hub · Lovable Browser Bridge",
  "version": "1.1.0",
  "description": "Inserisce prompt nella chat Lovable in modo robusto (textarea, contenteditable, editor custom).",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://lovable.dev/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": { "48": "icon.png", "128": "icon.png" },
  "content_scripts": [
    {
      "matches": ["https://lovable.dev/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
